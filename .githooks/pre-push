#!/usr/bin/env bash
# Erhöht die Patch-Version in plugin.json und marketplace.json vor jedem Push.
# Wird in den letzten Commit eingebaut (amend) — kein separater Bump-Commit nötig.

set -euo pipefail

PLUGIN_JSON=".claude-plugin/plugin.json"
MARKETPLACE_JSON=".claude-plugin/marketplace.json"

# Aktuelle Version aus plugin.json lesen
CURRENT=$(grep '"version"' "$PLUGIN_JSON" | head -1 | sed 's/.*"version": *"\([^"]*\)".*/\1/')
MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)

NEW_PATCH=$((PATCH + 1))
NEW_VERSION="$MAJOR.$MINOR.$NEW_PATCH"

# Beide Dateien aktualisieren
sed -i '' "s/\"version\": \"$CURRENT\"/\"version\": \"$NEW_VERSION\"/g" "$PLUGIN_JSON"
sed -i '' "s/\"version\": \"$CURRENT\"/\"version\": \"$NEW_VERSION\"/g" "$MARKETPLACE_JSON"

# In letzten Commit einbauen (der noch nicht gepusht wurde)
git add "$PLUGIN_JSON" "$MARKETPLACE_JSON"
git commit --amend --no-edit

echo "Version: $CURRENT → $NEW_VERSION"
